# ==================================================
# TAKVİM TAKİP - SUPABASE POSTGRESQL
# ==================================================
# This application uses Supabase PostgreSQL as the sole database.
# Do NOT use local databases, SQLite, or dual-server mode.

NODE_ENV=development
PORT=3000

# JWT - Required for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30m

# Frontend origin
FRONTEND_ORIGIN=https://tuzlabelafad.vercel.app

# ===== DATABASE CONFIGURATION =====
# REQUIRED: Supabase PostgreSQL connection string
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
# NO FALLBACKS - NO LOCAL DATABASES ALLOWED
# MUST BE SET FOR THE APPLICATION TO RUN
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# ===== SMTP / Mail Configuration =====
# Force environment-based SMTP settings (recommended for production)
SMTP_FORCE_ENV=1
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-user
SMTP_PASS=your-brevo-smtp-password
SMTP_FROM_EMAIL=your-sender-email@example.com
SMTP_FROM_NAME=Tuzla Belediyesi Afet İşleri

# ===== Initial Admin User =====
# Default super admin user (created automatically on first run)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin123!

# ===== PRODUCTION NOTES =====
# 1. DATABASE_URL is REQUIRED - application will not start without it
# 2. Only Supabase PostgreSQL is supported (SSL always enabled)
# 3. FOR RENDER: Set DATABASE_URL as environment variable in Render dashboard
# 4. FOR LOCAL DEV: Set DATABASE_URL in .env file above
